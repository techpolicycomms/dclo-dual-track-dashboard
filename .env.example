# data.gov.in API key — register at https://data.gov.in/user/register
DATA_GOV_IN_API_KEY=REPLACE_WITH_YOUR_KEY

# Cloudflare Radar API token (free) — create at dash.cloudflare.com → My Profile → API Tokens
# Required for: DCLO ACC weekly loop (dclo_weekly_acc.yml)
CLOUDFLARE_RADAR_TOKEN=REPLACE_WITH_YOUR_TOKEN

# OpenAQ API key (free) — register at explore.openaq.org
# Required for: DCLO OUT weekly loop (dclo_weekly_out.yml)
OPENAQ_API_KEY=REPLACE_WITH_YOUR_KEY

# Twilio credentials (survey automation)
TWILIO_ACCOUNT_SID=REPLACE_WITH_YOUR_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_TOKEN
TWILIO_FROM_NUMBER=REPLACE_WITH_YOUR_NUMBER

# Optional — WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_ID
WHATSAPP_PERMANENT_TOKEN=REPLACE_WITH_TOKEN

DATA_DIR=./data
