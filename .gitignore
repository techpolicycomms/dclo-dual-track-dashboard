.DS_Store
.env
.venv/
__pycache__/
*.pyc

# Local runtime artifacts
.streamlit/secrets.toml

# Keep gold outputs for dashboard, ignore heavy intermediates
data/raw/
data/curated/

# Knowledge base: raw ingested docs and generated outputs are local-only
# Wiki articles and index are tracked for portability
kb/raw/*
!kb/raw/.gitkeep
kb/outputs/*
!kb/outputs/.gitkeep
